# Fix incorrect language URIs

PREFIX dcterms: <http://purl.org/dc/terms/>

DELETE
	{ 	?s dcterms:language ?lang }
WHERE
	{ 	?s dcterms:language ?oldlang 
		VALUES (?oldlang ?lang) {
			( <http://publications.europa.eu/resource/authority/language/DUT> <http://publications.europa.eu/resource/authority/language/NLD> )
			( <http://publications.europa.eu/resource/authority/language/FRE> <http://publications.europa.eu/resource/authority/language/FRA> )
			( <http://publications.europa.eu/resource/authority/language/GER> <http://publications.europa.eu/resource/authority/language/DEU> )
		}
	}
