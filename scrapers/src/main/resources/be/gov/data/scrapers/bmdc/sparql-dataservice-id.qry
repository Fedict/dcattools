# Use generated IRI as DataService IRI

PREFIX dcat: <http://www.w3.org/ns/dcat#>

DELETE { 
		?s a dcat:DataService .
		?s ?p ?o }
INSERT 
	{	?uri a dcat:DataService .
		?uri ?p ?o }
WHERE
	{	?s a dcat:DataService .
		?s ?p ?o
		BIND (IRI(
				CONCAT("http://data.gov.be/.well-known/genid/dataservice/bmdc/",
					STRAFTER(STR(?s), "http://metadata.naturalsciences.be")
				)
			) as ?uri)
		FILTER (CONTAINS(STR(?s), "http://metadata.naturalsciences.be"))
	}