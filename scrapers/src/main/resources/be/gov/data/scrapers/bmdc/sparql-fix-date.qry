# Fix incorrect date data type

PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

DELETE 
	{	?s dcat:startDate "2010-06-15T18:00:00"^^xsd:date }
INSERT 
	{	?s dcat:startDate "2010-06-15T18:00:00"^^xsd:dateTime }
WHERE
	{	?s dcat:startDate "2010-06-15T18:00:00"^^xsd:date }