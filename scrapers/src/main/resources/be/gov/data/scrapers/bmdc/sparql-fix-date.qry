# Fix incorrect date data type

PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

DELETE 
	{	?s dcat:startDate ?time}
INSERT 
	{	?s dcat:startDate ?datetime }
WHERE
	{	?s dcat:startDate ?time .
		BIND(STRDT(STR(?time), xsd:dateTime) 
			AS ?datetime)
		FILTER ( datatype(?time) = xsd:date && (STRLEN(STR(?time)) > 10) )
	}
		