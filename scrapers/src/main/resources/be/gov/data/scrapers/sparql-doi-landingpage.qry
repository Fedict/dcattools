# Add landing page based on DOI identifier

PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

DELETE
	{	?s dcat:landingPage ?o }
INSERT
	{ 	?s dcat:landingPage ?page .
		?s foaf:page ?o }
WHERE
	{ 	?s a dcat:Dataset .
		?s dcterms:identifier ?id .
		OPTIONAL { ?s dcat:landingPage ?o }
		BIND (IRI(
			REPLACE(?id, "doi:", "https://doi.org/")
		) as ?page)
		FILTER(CONTAINS(?id, "doi:") && (?page != ?o))
	}