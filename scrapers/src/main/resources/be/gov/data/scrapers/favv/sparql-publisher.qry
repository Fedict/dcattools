# Set publisher to FAVV

PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>

DELETE
	{ 	?dataset dcterms:publisher ?publ .
		?publ ?p ?o }
INSERT
	{ 	?dataset dcterms:publisher <https://org.belgif.be/id/CbeRegisteredEntity/0267387230> }
WHERE
	{	?dataset dcterms:publisher ?publ .
		?publ ?p ?o }